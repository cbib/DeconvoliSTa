Bootstrap: localimage
From: /data/nejma/sif/sp_cell2location_h100.sif

# Overlay sur l'image cell2location du labo (sp_cell2location_h100.sif) pour
# remplacer torch 2.11.0+cu130 (CUDA 13.0, incompatible driver Apollo 570/CUDA
# 12.8) par la MEME version torch 2.11.0 buildée pour CUDA 12.8 (cu128).
# Aucun autre paquet n'est touché : scvi-tools / cell2location / lightning
# restent identiques (prouvés fonctionnels en CPU).
#
# Build (sila, internet + fakeroot requis) :
#   singularity build --fakeroot sp_cell2location_cu128.sif cell2location_cu128.def

%post
    PIP=/opt/conda/envs/cell2loc_env/bin/pip
    PY=/opt/conda/envs/cell2loc_env/bin/python

    # Remplace torch par la build cu128 (CUDA 12.8). L'index pytorch fournit
    # torch + ses libs nvidia-*-cu12 ; PyPI couvre les deps pures-python.
    $PIP install --force-reinstall --no-cache-dir \
        torch==2.11.0+cu128 \
        --index-url https://download.pytorch.org/whl/cu128 \
        --extra-index-url https://pypi.org/simple

    # Vérifie que la build CUDA est bien 12.8 (is_available se teste sur GPU réel)
    $PY -c "import torch; print('torch', torch.__version__, '| cuda build', torch.version.cuda)"

%test
    /opt/conda/envs/cell2loc_env/bin/python -c "import torch; assert torch.version.cuda.startswith('12.8'), torch.version.cuda; print('OK torch cuda', torch.version.cuda)"

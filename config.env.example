# =============================================================================
# DeconvoliSTa - environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `config.env` and adapt EVERY value to your environment:
#     cp config.env.example config.env && nano config.env
# Launch scripts (via ./launch.sh) source `config.env`.
# `config.env` is gitignored, so your personal paths never reach the repo.
# The values below are placeholders/examples — replace them.
# =============================================================================

# --- Paths (absolute paths on the machine that runs the pipeline) ---
DECONVOLISTA_DIR="/path/to/DeconvoliSTa"   # repo root on the compute machine
OUTPUT_DIR="$DECONVOLISTA_DIR/res"         # where results are written
LOG_DIR="$DECONVOLISTA_DIR/logs"           # SLURM logs (.out/.err)
SIF_DIR="$DECONVOLISTA_DIR/sif"            # Singularity images (.sif) directory
DATA_BIND="/path/to/data"                  # data directory to expose to containers (bind mount)

# --- Conda / environment ---
CONDA_SETUP="$HOME/miniconda3/etc/profile.d/conda.sh"  # path to your conda.sh init script
CONDA_ENV="snakemake"                      # conda env that provides snakemake

# --- SLURM (only used when submitting via ./deconvolista on an HPC cluster) ---
PARTITION_CPU="compute"                    # CPU partition name
PARTITION_GPU="gpu"                        # GPU partition name
GPU_GRES="gpu:1"                           # GPU request, e.g. "gpu:1" or an MIG slice "gpu:nvidia_h100_nvl_1g.24gb"
CUDA_MODULE=""                             # CUDA module to `module load` (leave empty if not using environment modules)

# --- SLURM job resources (./deconvolista passes these to sbatch per job type) ---
MEM_CPU="128G"                             # memory for the CPU deconvolution job
MEM_GPU="100G"                             # memory for a GPU job (cell2location / ddls)
MEM_VISU="64G"                             # memory for the visualization job
TIME_LIMIT="24:00:00"                      # wall-clock limit for every job

# --- Run defaults (overridable on the fly: e.g. METHODS=... ./deconvolista, or flags) ---
# Written as ${VAR:-default} so an env var passed on the command line takes precedence and is
# NOT clobbered when the scripts source this file (a plain assignment would overwrite it).
DEFAULT_METHODS="${DEFAULT_METHODS:-rctd,nnls,spatialdwls,cell2location,ddls}"  # menu default
DO_VISU="${DO_VISU:-true}"                  # build the visualization by default
BAYES_Q="${BAYES_Q:-auto}"                  # BayesSpace q (number, or "auto")
SKIP_METRICS="${SKIP_METRICS:-true}"        # skip metrics when there is no ground truth
MAP_GENES="${MAP_GENES:-false}"             # map gene symbols <-> Ensembl (e.g. GBMap reference)

# --- Default input data ---
SC_INPUT="${SC_INPUT:-unit-test/test_sc_data.rds}"
SP_INPUT="${SP_INPUT:-unit-test/test_sp_data.rds}"
ANNOT="${ANNOT:-subclass}"

# =============================================================================
# DeconvoliSTa - environment configuration
# -----------------------------------------------------------------------------
# Copy this file to `config.env` and adapt the values to YOUR environment:
#     cp config.env.example config.env && nano config.env
# Launch scripts (via ./launch.sh) source `config.env`.
# `config.env` is gitignored, so your personal paths never reach the repo.
# The values below are the CBiB Apollo cluster defaults, given as an example.
# =============================================================================

# --- Paths ---
DECONVOLISTA_DIR="/scratch/nmoualhi/DeconvoliSTa"   # repo root on the compute machine
OUTPUT_DIR="/scratch/nmoualhi/res"                  # where results are written
LOG_DIR="/scratch/nmoualhi/logs"                    # SLURM logs (.out/.err)
SIF_DIR="/scratch/nmoualhi/sif"                     # Singularity images (.sif) directory
DATA_BIND="/mnt/cbib/RetinRNA/spatial"              # data mount to expose to containers (bind)

# --- Conda / environment ---
CONDA_SETUP="/isilon/modules/apps/conda/etc/profile.d/conda.sh"  # conda init script
CONDA_ENV="snakemake"                               # conda env that provides snakemake

# --- SLURM ---
PARTITION_CPU="compute"                             # CPU partition
PARTITION_GPU="gpu"                                 # GPU partition
GPU_GRES="gpu:nvidia_h100_nvl_1g.24gb"              # GPU resource (H100 MIG); see `scontrol show node <gpu>`
CUDA_MODULE="nvidia/cuda/12.9"                      # CUDA module to load (leave empty if not applicable)

# --- Default input data (overridable on the fly) ---
SC_INPUT="unit-test/test_sc_data.rds"
SP_INPUT="unit-test/test_sp_data.rds"
ANNOT="subclass"
